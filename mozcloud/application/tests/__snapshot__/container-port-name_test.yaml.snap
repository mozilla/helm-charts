        - type: NamedAddress
          value: mozcloud-dev-ip-v4
      gatewayClassName: gke-l7-global-external-managed
      listeners:
        - allowedRoutes:
            namespaces:
              from: Same
          name: http
          port: 80
          protocol: HTTP
        - allowedRoutes:
            namespaces:
              from: Same
          name: https
          port: 443
          protocol: HTTPS
  4: |
