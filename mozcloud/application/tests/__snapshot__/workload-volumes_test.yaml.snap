Configuration matches entire snapshot:
  1: |
    apiVersion: v1
    kind: PersistentVolumeClaim
    metadata:
      annotations:
        argocd.argoproj.io/sync-wave: "-11"
      labels:
        app.kubernetes.io/component: pvc
        app.kubernetes.io/managed-by: argocd
        app.kubernetes.io/name: mozcloud-test
        app_code: mozcloud-test
        component_code: pvc
        env_code: dev
        helm.sh/chart: test-chart
        mozcloud_chart: mozcloud
        mozcloud_chart_version: 1.0.0
        realm: nonprod
      name: pvc-rwm
    spec:
      accessModes:
        - ReadWriteOnce
        - ReadWriteMany
      resources:
        requests:
          storage: 50Gi
      storageClassName: mozilla-enterprise-rwx
  2: |
    apiVersion: v1
    kind: PersistentVolumeClaim
    metadata:
      annotations:
        argocd.argoproj.io/sync-wave: "-11"
      labels:
        app.kubernetes.io/component: pvc
        app.kubernetes.io/managed-by: argocd
        app.kubernetes.io/name: mozcloud-test
        app_code: mozcloud-test
